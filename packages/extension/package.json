{
  "name": "@zitiernudel/extension",
  "description": "Markiere eine Quelle im Browser, klick auf die Nudel, und bekomme einen fertigen BibTeX-Eintrag im hu-jura Format. Für alle, die lieber schreiben als zitieren.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "check": "eslint --max-warnings=0 . && tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@zitiernudel/core": "workspace:*",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^9",
    "eslint-config-sheriff": "^31.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}